    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.1",
    "cypress": "^15.13.0",
    "jsdom": "^29.0.1",
    "vite": "^6.1.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.1"
  }
